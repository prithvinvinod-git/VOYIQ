
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the VOYIQ application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has a premium subscription."
        },
        "activeCollabRoomId": {
          "type": "string",
          "description": "The ID of the collab room the user is currently in."
        }
      },
      "required": [
        "id",
        "name",
        "email"
      ]
    },
    "CollabRoom": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CollabRoom",
      "type": "object",
      "description": "A collaborative room where users can plan trips together.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The random join code (e.g., A7B2X)."
        },
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Trip": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Trip",
      "type": "object",
      "description": "Represents a travel plan.",
      "properties": {
        "id": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "collabRoomId": {
          "type": "string",
          "description": "Optional reference to a collab room if this trip was created within one."
        },
        "destination": {
          "type": "string"
        },
        "startDate": {
          "type": "string"
        },
        "endDate": {
          "type": "string"
        },
        "budgetTotal": {
          "type": "number"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "ownerId",
        "destination",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          }
        }
      },
      {
        "path": "/collabRooms/{roomId}",
        "definition": {
          "entityName": "CollabRoom",
          "schema": {
            "$ref": "#/backend/entities/CollabRoom"
          }
        }
      },
      {
        "path": "/collabRooms/{roomId}/members/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Users currently active in the room."
        }
      },
      {
        "path": "/trips/{tripId}",
        "definition": {
          "entityName": "Trip",
          "schema": {
            "$ref": "#/backend/entities/Trip"
          }
        }
      }
    ]
  }
}
