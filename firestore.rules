rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOYIQ SECURITY RULES
     * 
     * Enforces strict ownership for user profiles and collaborative access for trips.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- USER RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- TRIP RULES (Recursive) ---

    /**
     * Rules for Trips and all their subcollections (itineraryDays, expenses, chat).
     * Uses a recursive wildcard for consistent authorization across the tree.
     */
    match /trips/{tripId} {
      // Allow listing trips where the user is an authorized collaborator
      allow list: if isSignedIn() && request.auth.uid in resource.data.authorizedUserIds;
      
      // Allow get/create/update if the user is part of the trip
      allow get, create, update: if isSignedIn() && (
        (resource == null) || // For create
        (request.auth.uid in resource.data.authorizedUserIds) ||
        (request.auth.uid == resource.data.ownerId)
      );
      
      // Only the owner can delete a trip
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Sub-collections inherit trip-level access or use simplified checks
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}