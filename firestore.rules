rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOYIQ SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a hybrid security model: strict path-based ownership for personal user
     * profiles and a shared-access collaborator model for travel trips.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user's UID is present in a list of authorized IDs. */
    function isAuthorized(authorizedList) {
      return isSignedIn() && authorizedList != null && request.auth.uid in authorizedList;
    }

    /** @description Helper to check parent trip authorization via a document fetch. */
    function isParentTripAuthorized(tripId) {
      return isSignedIn() && exists(/databases/$(database)/documents/trips/$(tripId)) && 
             request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.authorizedUserIds;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User collection. Restricted to the user themselves.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for Trips. Access for owners and listed collaborators.
     */
    match /trips/{tripId} {
      allow get, list: if isAuthorized(resource.data.authorizedUserIds);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.auth.uid in request.resource.data.authorizedUserIds;
      allow update: if isAuthorized(resource.data.authorizedUserIds) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if resource != null && isOwner(resource.data.ownerId);
    }

    /**
     * @description Rules for ItineraryDays. Access controlled by parent trip authorization.
     */
    match /trips/{tripId}/itineraryDays/{itineraryDayId} {
      allow get, list: if isParentTripAuthorized(tripId);
      allow create, update, delete: if isParentTripAuthorized(tripId) && (request.resource == null || request.resource.data.tripId == tripId);
    }

    /**
     * @description Rules for ItinerarySlots (activities).
     */
    match /trips/{tripId}/itineraryDays/{itineraryDayId}/itinerarySlots/{itinerarySlotId} {
      allow get, list: if isParentTripAuthorized(tripId);
      allow create, update, delete: if isParentTripAuthorized(tripId);
    }

    /**
     * @description Rules for Expenses.
     */
    match /trips/{tripId}/expenses/{expenseId} {
      allow get, list: if isParentTripAuthorized(tripId);
      allow create: if isParentTripAuthorized(tripId) && request.resource.data.loggedByUserId == request.auth.uid;
      allow update, delete: if isParentTripAuthorized(tripId);
    }

    /**
     * @description Rules for AI Chat Messages.
     */
    match /trips/{tripId}/chatMessages/{messageId} {
      allow get, list: if isParentTripAuthorized(tripId);
      allow create: if isParentTripAuthorized(tripId);
      allow update, delete: if isParentTripAuthorized(tripId);
    }

  }
}