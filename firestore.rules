rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOYIQ SECURITY RULES DOCUMENTATION
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a hybrid security model: strict path-based ownership for personal user
     * profiles and a shared-access collaborator model for travel trips. To ensure high performance 
     * and rule simplicity, authorization data is denormalized across the hierarchy.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Private user profiles and preferences.
     * - /trips/{tripId}: Collaborative trip plans.
     * - /trips/{tripId}/...: Subcollections (itinerary, expenses, chat) inherit security from the trip.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Subcollection documents (e.g., expenses) contain denormalized 
     *    'tripAuthorizedUserIds' to allow rules to verify access without performing costly get() calls 
     *    to parent documents.
     * 2. Fallback Authorization: As a safety measure for data consistency, rules can fall back 
     *    to checking the parent Trip document's 'authorizedUserIds'.
     * 3. Collaborator Model: Trips use an 'authorizedUserIds' array (containing owner and collaborators).
     *    Access is granted if the authenticated user's UID is present in this list.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user's UID is present in a list of authorized IDs. */
    function isAuthorized(authorizedList) {
      return isSignedIn() && authorizedList != null && request.auth.uid in authorizedList;
    }

    /** @description Helper to check parent trip authorization via a document fetch. */
    function isParentTripAuthorized(tripId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.authorizedUserIds;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User collection. Restricted to the user themselves.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rules for Trips. Access for owners and listed collaborators.
     */
    match /trips/{tripId} {
      allow get, list: if isAuthorized(resource.data.authorizedUserIds);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.auth.uid in request.resource.data.authorizedUserIds;
      allow update: if isAuthorized(resource.data.authorizedUserIds) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if resource != null && isOwner(resource.data.ownerId);
    }

    /**
     * @description Rules for ItineraryDays. Inherits trip authorization via denormalized fields or parent check.
     */
    match /trips/{tripId}/itineraryDays/{itineraryDayId} {
      allow get, list: if isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId);
      allow create: if (isAuthorized(request.resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.tripId == tripId;
      allow update: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.tripId == resource.data.tripId;
      allow delete: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId));
    }

    /**
     * @description Rules for ItinerarySlots (activities). Inherits trip authorization.
     */
    match /trips/{tripId}/itineraryDays/{itineraryDayId}/itinerarySlots/{itinerarySlotId} {
      allow get, list: if isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId);
      allow create: if (isAuthorized(request.resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.tripId == tripId;
      allow update: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.tripId == resource.data.tripId;
      allow delete: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId));
    }

    /**
     * @description Rules for Expenses.
     */
    match /trips/{tripId}/expenses/{expenseId} {
      allow get, list: if isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId);
      allow create: if (isAuthorized(request.resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.loggedByUserId == request.auth.uid && request.resource.data.tripId == tripId;
      allow update: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.loggedByUserId == resource.data.loggedByUserId;
      allow delete: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId));
    }

    /**
     * @description Rules for AI Chat Messages.
     */
    match /trips/{tripId}/chatMessages/{messageId} {
      allow get, list: if isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId);
      allow create: if (isAuthorized(request.resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.tripId == tripId;
      allow update: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId)) && request.resource.data.tripId == resource.data.tripId;
      allow delete: if (isAuthorized(resource.data.tripAuthorizedUserIds) || isParentTripAuthorized(tripId));
    }

  }
}