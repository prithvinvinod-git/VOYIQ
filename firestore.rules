
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOYIQ SECURITY RULES
     * 
     * Enforces strict ownership for user profiles and collaborative access for trips.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the user is a member of a specific room
    function isRoomMember(roomId) {
      return isSignedIn() && exists(/databases/$(database)/documents/collabRooms/$(roomId)/members/$(request.auth.uid));
    }

    // --- USER RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- COLLAB ROOM RULES ---

    match /collabRooms/{roomId} {
      allow read, create, update: if isSignedIn();
      
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /members/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /messages/{messageId} {
        // Only members can read or send messages in a room
        allow read, create: if isRoomMember(roomId);
      }
    }

    // --- TRIP RULES (Recursive) ---

    match /trips/{tripId} {
      allow get: if isSignedIn() && (
        (request.auth.uid in (resource.data.authorizedUserIds || [])) ||
        (request.auth.uid == resource.data.ownerId) ||
        (resource.data.collabRoomId != null)
      );

      allow list: if isSignedIn();
      
      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        (request.auth.uid in (resource.data.authorizedUserIds || [])) ||
        (request.auth.uid == resource.data.ownerId) ||
        (resource.data.collabRoomId != null)
      );
      
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
